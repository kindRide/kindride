# Copy to backend/.env and fill in (never commit real secrets).

# Same project URL as the app (Settings -> API -> Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role key — server only. Settings -> API -> service_role (secret).
# This key bypasses RLS so the backend can write points safely after it validates the user JWT.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — server only. Settings -> API -> JWT Secret (not the anon key).
# Used to verify the user's access token from Authorization: Bearer ...
SUPABASE_JWT_SECRET=

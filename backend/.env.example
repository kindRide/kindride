# Copy to backend/.env and fill in (never commit real secrets).

# Same project URL as the app (Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Privileged key for PostgREST (server only).
# Prefer legacy service_role JWT (eyJ...) from API → Legacy API keys if sb_secret fails.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — Settings → JWT Keys → Legacy JWT secret (not the anon key).
SUPABASE_JWT_SECRET=

# Optional: allow POST /rides/request-driver without driver_presence eligibility checks (local debugging only).
# KINDRIDE_RELAX_DRIVER_REQUEST_ELIGIBILITY=true

# Optional: Twilio for SOS SMS alerts (requires account at twilio.com).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_PHONE_NUMBER=+1234567890

# P2.1 — Stripe Identity verification.
# STRIPE_WEBHOOK_SECRET — from Stripe Dashboard → Webhooks → signing secret.
# KINDRIDE_REQUIRE_ID_VERIFIED=true — hard-filter unverified drivers from matching (default: off, score boost only).
# STRIPE_WEBHOOK_SECRET=whsec_...
# KINDRIDE_REQUIRE_ID_VERIFIED=false

# Stripe Connect — voluntary tipping.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_TIP_WEBHOOK_SECRET=whsec_...
# STRIPE_CONNECT_RETURN_URL=kindride://connect/return

# Copy to backend/.env and fill in (never commit real secrets).

# Same project URL as the app (Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Privileged key for PostgREST (server only).
# Prefer legacy service_role JWT (eyJ...) from API → Legacy API keys if sb_secret fails.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — Settings → JWT Keys → Legacy JWT secret (not the anon key).
SUPABASE_JWT_SECRET=
